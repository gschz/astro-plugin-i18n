{
  "name": "@gschz/astro-plugin-i18n",
  "version": "1.2.6",
  "description": "Internationalization (i18n) plugin for Astro, focused on simplicity, SSR-first and reactive client updates.",
  "type": "module",
  "author": "Gera Schz <gschz.git@gmail.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "browser": {
        "types": "./dist/client.d.mts",
        "import": "./dist/client.mjs"
      }
    },
    "./components/*.astro": "./dist/components/*.astro",
    "./components/*": {
      "import": "./dist/components/*.mjs",
      "types": "./dist/components/*.d.mts"
    },
    "./integration": {
      "import": "./dist/integration.mjs",
      "types": "./dist/integration.d.mts"
    },
    "./client": {
      "import": "./dist/client.mjs",
      "types": "./dist/client.d.mts"
    },
    "./middleware-entrypoint": {
      "import": "./dist/middleware-entrypoint.mjs",
      "types": "./dist/middleware-entrypoint.d.mts"
    },
    "./schema": {
      "import": "./dist/schema.mjs",
      "types": "./dist/schema.d.mts"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsdown && bun run build:cp-astro && bun run build:fix-imports",
    "build:cp-astro": "copyfiles -u 2 \"src/components/**/*.astro\" dist/components",
    "build:fix-imports": "bun run scripts/fix-astro-imports.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "astro check && tsc --noEmit",
    "demo:dev": "cd demo && bun run dev",
    "demo:check": "cd demo && bun run astro check",
    "demo:build": "cd demo && bun run build",
    "demo:preview": "cd demo && bun run preview",
    "version:rc": "npm version prerelease --preid rc --no-git-tag-version",
    "publish": "bun publish --access public",
    "publish:next": "bun publish --access public --tag next",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "astro",
    "astro-plugin",
    "astro-integration",
    "i18n",
    "internationalization",
    "translation"
  ],
  "peerDependencies": {
    "astro": ">=6.0.0",
    "react": ">=19.0.0",
    "react-dom": "^19.2.4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "astro": "^6.3.3",
    "astro-eslint-parser": "^1.4.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "https://github.com/gschz/astro-plugin-i18n"
  },
  "bugs": {
    "url": "https://github.com/gschz/astro-plugin-i18n/issues"
  },
  "homepage": "",
  "publishConfig": {
    "access": "public"
  }
}
