---
/**
 * Componente Astro para SEO multilingue.
 *
 * Genera automaticamente:
 * - enlaces `hreflang` por idioma soportado,
 * - enlace `hreflang="x-default"` opcional,
 * - meta tags Open Graph (`og:locale` y `og:locale:alternate`) cuando
 *   se proporciona `localeMap`.
 *
 * Respeta la estrategia de routing configurada en el plugin
 * (`manual`, `prefix`, `prefix-except-default`) para construir URLs canonicas
 * por idioma de forma consistente.
 */
import type { Language } from '../types';
import { getConfig } from '../core/config';
import { getCurrentLanguage } from '../core/language';
import { getAlternateLinks, getXDefaultHref } from '../core/seo';

/**
 * Props del componente `I18nHead`.
 */
interface Props {
  /** Idioma actual; si no se define, se resuelve desde `Astro.locals`. */
  currentLang?: Language;
  /** Path actual de la pagina; por defecto usa `Astro.url.pathname`. */
  currentPath?: string;
  /** URL base absoluta del sitio (ej: `https://example.com`). */
  siteUrl?: string;
  /** Mapa opcional para Open Graph locales (ej: `{ es: 'es_ES', en: 'en_US' }`). */
  localeMap?: Record<string, string>;
  /** Si es `true`, agrega enlace `hreflang="x-default"`. Por defecto `true`. */
  includeXDefault?: boolean;
}

const { currentLang, currentPath, siteUrl, localeMap = {}, includeXDefault = true } = Astro.props as Props;

const config = getConfig();
const resolvedPath = currentPath ?? Astro.url.pathname;
const resolvedLang = currentLang ?? getCurrentLanguage(Astro.locals as Record<string, any> | undefined);
const resolvedSiteUrl = siteUrl ?? Astro.site?.toString() ?? Astro.url.origin;
const alternateLinks = getAlternateLinks(resolvedPath, resolvedSiteUrl, config);
const xDefaultHref = getXDefaultHref(resolvedPath, resolvedSiteUrl, config);
const currentLocale = localeMap[resolvedLang as string];
const alternateLocales = alternateLinks
  .map((entry) => localeMap[entry.lang])
  .filter((locale): locale is string => typeof locale === 'string' && locale.length > 0)
  .filter((locale) => locale !== currentLocale);
---

{alternateLinks.map((entry) => <link rel="alternate" hreflang={entry.lang} href={entry.href} />)}
{includeXDefault && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}
{currentLocale && <meta property="og:locale" content={currentLocale} />}
{alternateLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
