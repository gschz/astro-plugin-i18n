# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.astro text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.mjs text eol=lf

# Config files
.editorconfig text eol=lf
.eslintrc* text eol=lf
.prettierrc* text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.woff binary
*.woff2 binary
